# Backend runtime config (copy to /etc/myopia/server.env)
MYOPIA_DATABASE_URL=postgresql+psycopg://myopia:myopia@127.0.0.1:5432/myopia
MYOPIA_MODEL_DIR=/opt/myopia_app/models
MYOPIA_DEFAULT_DEVICE=cpu
MYOPIA_STORAGE_BACKEND=local
MYOPIA_LOCAL_STORAGE_DIR=/opt/myopia_app/storage
# Set to your real doctor/ops client origins. Avoid '*'.
MYOPIA_ALLOWED_ORIGINS=https://doctor.example.com,https://ops.example.com
# Use a strong random secret in production.
MYOPIA_AUTH_SECRET=replace-with-64-char-random-secret
MYOPIA_AUTH_TOKEN_TTL_MINUTES=480
MYOPIA_MAX_VISITS=5
MYOPIA_MAX_INLINE_IMAGE_BYTES=8388608
MYOPIA_MAX_INLINE_TOTAL_BYTES=33554432
MYOPIA_SKIP_STARTUP_CHECK=0
# Security baseline: keep legacy public clinical routes disabled.
MYOPIA_ENABLE_LEGACY_PUBLIC_CLINICAL_ROUTES=0
# First-run setup wizard controls.
MYOPIA_SETUP_ENABLED=1
MYOPIA_SETUP_ENFORCE_LOCK=1
# Optional; defaults to <repo>/.myopia_installed
# MYOPIA_INSTALL_MARKER_FILE=/opt/myopia_app/.myopia_installed
